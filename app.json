{
  "expo": {
    "name": "mBowl",
    "slug": "mbowl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C0C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "mbowl",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.marcus.mbowl",
      "buildNumber": "1",
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      ["expo-notifications", { "icon": "./assets/images/icon.png", "color": "#00CEC9" }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68d5550e-d0d4-4b52-ad26-2a3258a51233"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/68d5550e-d0d4-4b52-ad26-2a3258a51233",
      "requestHeaders": { "expo-channel-name": "production" }
    }
  }
}
